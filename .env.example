# ── PrepMeAI Environment Variables ───────────────────────────────────────────
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: Groq API Key
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED: Path to NCERT PDF (relative to project root)
# Download the PDF and place it in the project root
PDF_PATH=ncert_science_8.pdf

# OPTIONAL: Groq model overrides (defaults work fine)
# GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
# GROQ_MODEL_FALLBACK=llama3-70b-8192
