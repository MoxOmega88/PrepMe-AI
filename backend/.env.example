# ── Backend Environment Variables ────────────────────────────────────────────
# 1. Copy this file:   cp backend/.env.example backend/.env
# 2. Fill in your values below
# 3. NEVER commit backend/.env to git
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: Groq API Key
# Get yours free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# REQUIRED: Path to NCERT PDF (relative to backend directory)
PDF_PATH=../ncert_science_8.pdf

# OPTIONAL: Database URL (SQLite default, no changes needed locally)
# DATABASE_URL=sqlite+aiosqlite:///./prepmeai.db

# OPTIONAL: Groq model overrides
# GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
# GROQ_MODEL_FALLBACK=llama3-70b-8192

# OPTIONAL: Security (change in production!)
# SECRET_KEY=your-secret-key-change-in-production
